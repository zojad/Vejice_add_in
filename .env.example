VEJICE_API_KEY='vejice_API_beta'
# Set to true to bypass the live API and return mock corrections locally.
VEJICE_USE_MOCK=false
VEJICE_API_URL='https://127.0.0.1:4001/api/postavi_vejice'
VEJICE_QUIET_LOGS=false
VEJICE_ERROR_LOGS=true
VEJICE_ONLINE_VERBOSE_LOGS=false
VEJICE_ONLINE_DRIFT_LOGS=false
VEJICE_DEBUG=false
VEJICE_VERBOSE_LOGS=true
VEJICE_DESKTOP_VERBOSE_LOGS=true
VEJICE_QUOTE_TRACE_VERBOSE=true

# Enable LingHub lemma offsets so we anchor commas precisely.
VEJICE_USE_LEMMATIZER=true
VEJICE_LEMMATIZER_ANCHORS=true
VEJICE_LEMMAS_URL='https://127.0.0.1:4001/lemmas'
VEJICE_LEMMAS_TIMEOUT_MS=90000
VEJICE_ONLINE_CHECK_TIMEOUT_MS=10800000
VEJICE_ONLINE_PARAGRAPH_TIMEOUT_MS=240000
VEJICE_CHECK_RUN_WATCHDOG_MS=10800000
VEJICE_API_TIMEOUT_MS=45000
VEJICE_CHECK_MAX_PARTIAL_PASSES=1200
VEJICE_DESKTOP_CHECK_MAX_PARTIAL_PASSES=1200
VEJICE_CHECK_MAX_REPEATED_PROGRESS=40
VEJICE_DESKTOP_CHECK_BATCH_PAGES=5
VEJICE_DESKTOP_CHECK_CHARS_PER_PAGE=2500
VEJICE_DESKTOP_CHECK_BATCH_PARAGRAPHS=260
VEJICE_ONLINE_CHECK_BATCH_PARAGRAPHS=120

# Lemmatizer proxy configuration (adjust when you deploy your own endpoint)
LEMMAS_PROXY_PORT=5050
LEMMAS_PROXY_TARGET_URL=http://46.101.236.89:8001/analyze
LEMMAS_PROXY_TARGET_API_KEY=''
LEMMAS_PROXY_TARGET_API_KEY_HEADER='X-API-KEY'
LEMMAS_PROXY_SHARED_TOKEN=''
LEMMAS_PROXY_SHARED_TOKEN_HEADER='x-lemmas-token'
LEMMAS_PROXY_TIMEOUT_MS=120000
LEMMAS_PROXY_BODY_LIMIT_BYTES=262144
LEMMAS_PROXY_ALLOWED_ORIGINS=https://127.0.0.1:4001,https://localhost:4001
LEMMAS_PROXY_SSL_KEY_PATH=''
LEMMAS_PROXY_SSL_CERT_PATH=''

VEJICE_PROXY_PORT=5051
VEJICE_PROXY_TARGET_URL='https://gpu-proc1.cjvt.si/popravljalnik-api/postavi_vejice'
VEJICE_PROXY_TARGET_API_KEY=''
VEJICE_PROXY_TIMEOUT_MS=120000
VEJICE_PROXY_BODY_LIMIT_BYTES=262144
VEJICE_PROXY_ALLOWED_ORIGINS=https://127.0.0.1:4001,https://localhost:4001
VEJICE_PROXY_SSL_KEY_PATH=''
VEJICE_PROXY_SSL_CERT_PATH=''
